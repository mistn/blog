# 复制为 .env，填入实际值
# .env 已加入 .gitignore，不会提交到仓库

# ---- Keystatic 管理后台 ----
# 以下三项仅生产环境（Vercel）需要，本地开发无需填写
# GitHub OAuth App: Settings > Developer settings > OAuth Apps
# Callback URL: https://你的域名/keystatic/github/callback
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# 后台 Basic Auth（本地无需，部署必填）
# ADMIN_USER=
# ADMIN_PASS=

# ---- UptimeRobot 监控 ----
UPROBOT_API_KEY=ur3569564-05e5147490b18828bc1b1ccd

# ---- AniList 追番同步 ----
# 留空则使用脚本中硬编码的默认值 miuo55
# ANILIST_USER_NAME=
# ANILIST_USER_ID=

# ---- 可选 ----
# GITHUB_TOKEN=
# PUBLIC_GOOGLE_SITE_VERIFICATION=

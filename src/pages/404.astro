---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui } from "@/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
---

<Layout title={`404 ${copy.pages.notFoundTitle} | ${SITE.title}`} description={copy.pages.notFoundDesc}>
  <main
    id="main-content"
    class="app-layout min-h-[80vh] flex flex-col items-center justify-center"
  >
    <div class="flex flex-col items-center text-center">
      <p class="text-[10rem] sm:text-[12rem] font-black leading-none text-accent select-none">
        404
      </p>
      <p class="mt-2 text-xl sm:text-2xl font-medium text-foreground/80">
        {copy.pages.notFoundTitle}
      </p>
      <p class="mt-2 max-w-sm text-sm text-foreground/40 leading-relaxed">
        {copy.pages.notFoundDesc}
      </p>
      <a
        href={localizePath("/", locale)}
        class="mt-8 inline-flex items-center gap-1.5 rounded-xl bg-accent px-5 py-2.5 text-sm font-medium text-white transition hover:opacity-85"
      >
        {copy.pages.notFoundCta}
      </a>
    </div>
  </main>

</Layout>

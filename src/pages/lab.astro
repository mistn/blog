---
import PageHeader from "@/components/PageHeader.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import { getLocaleFromPath, ui } from "@/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const pageTitle = copy.pages.labFullTitle;
const pageDescription = copy.pages.labDesc;
---

<Layout title={pageTitle} description={pageDescription}>
  <SiteTopbar />

  <main class="mx-auto w-full max-w-4xl px-4 sm:px-6 pt-8 pb-10 md:pt-12 md:pb-14">
    <PageHeader title={copy.pages.labTitle} />

    <div class="pt-8">
      <section id="uptime-monitors">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-lg font-semibold text-foreground">UptimeRobot 监控</h2>
          <div id="monitor-status-bar" class="flex items-center gap-3 text-xs text-foreground/50">
            <span class="flex items-center gap-1.5"><span class="inline-block size-2 rounded-full bg-green-500"></span> UP</span>
            <span class="flex items-center gap-1.5"><span class="inline-block size-2 rounded-full bg-red-500"></span> DOWN</span>
            <span class="flex items-center gap-1.5"><span class="inline-block size-2 rounded-full bg-yellow-500"></span> 异常</span>
          </div>
        </div>
        <div id="monitor-grid" class="grid gap-3 sm:grid-cols-2">
          <div class="col-span-full flex items-center justify-center py-12 text-sm text-foreground/40">
            <svg class="size-5 mr-2 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
            加载中...
          </div>
        </div>
        <p id="monitor-updated" class="mt-4 text-xs text-foreground/35 text-right"></p>
      </section>
    </div>
  </main>
</Layout>

<style is:global>
  @keyframes dot-breathe {
    0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 currentColor; }
    50% { opacity: 0.5; transform: scale(1.8); box-shadow: 0 0 8px 2px currentColor; }
  }
  .status-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    animation: dot-breathe 2.5s ease-in-out infinite;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .status-dot:hover {
    transform: scale(3);
    box-shadow: 0 0 12px 4px currentColor;
    animation: none;
  }
  .status-badge {
    transition: box-shadow 0.2s ease;
  }
  .status-badge:hover {
    box-shadow: 0 0 12px 2px currentColor;
  }
  .status-bar {
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .status-bar:hover {
    transform: scaleY(1.25);
    opacity: 0.85;
  }
</style>

<script>
// @ts-nocheck
  const STATUS_MAP = {
    0: { label: "Paused", color: "#9ca3af", bg: "rgba(156,163,175,0.1)" },
    1: { label: "Pending", color: "#eab308", bg: "rgba(234,179,8,0.1)" },
    2: { label: "UP", color: "#22c55e", bg: "rgba(34,197,94,0.1)" },
    8: { label: "Seems Down", color: "#eab308", bg: "rgba(234,179,8,0.1)" },
    9: { label: "DOWN", color: "#ef4444", bg: "rgba(239,68,68,0.1)" },
  };

  const DAY = 86400;
  const STATUS_DAYS = 30;

  function getDateRanges() {
    const now = Math.floor(Date.now() / 1000);
    const ranges = [];
    const dates = [];
    for (let i = STATUS_DAYS - 1; i >= 0; i--) {
      const start = Math.floor((now - (i + 1) * DAY) / DAY) * DAY;
      const end = start + DAY;
      ranges.push(`${start}_${end}`);
      dates.push(start);
    }
    const overall = `${ranges[0].split("_")[0]}_${ranges[ranges.length - 1].split("_")[1]}`;
    ranges.push(overall);
    return { ranges: ranges.join("-"), dates };
  }

  function dayColor(percent) {
    if (percent == null || percent === undefined) return "#8882";
    if (percent >= 99) return "#22c55e";
    if (percent >= 95) return "#eab308";
    return "#ef4444";
  }

  function dayTitle(date, percent, currentStatus) {
    const d = new Date(date * 1000).toLocaleDateString("zh-CN", { month: "short", day: "numeric" });
    if (percent == null || percent === undefined) {
      return `${d} ${STATUS_MAP[currentStatus]?.label || ""}`;
    }
    return `${d} 可用率 ${percent.toFixed(1)}%`;
  }

  function computeAvgResponseTime(responseTimes) {
    if (!responseTimes || responseTimes.length === 0) return null;
    let sum = 0, count = 0;
    for (const rt of responseTimes) {
      if (rt.value != null) { sum += rt.value; count++; }
    }
    return count > 0 ? Math.round(sum / count) : null;
  }

  function parseDailyRatios(rangesStr) {
    if (!rangesStr) return [];
    const parts = rangesStr.split("-").map(v => parseFloat(v));
    if (parts.length >= STATUS_DAYS + 1) parts.pop();
    return parts;
  }

  async function fetchMonitors() {
    const grid = document.getElementById("monitor-grid");
    if (!grid) return;

    try {
      const res = await fetch("/api/monitors");
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const monitors = await res.json();
      if (monitors.error) throw new Error(monitors.error);
      renderMonitors(monitors);
    } catch (err) {
      const g = document.getElementById("monitor-grid");
      if (g) g.innerHTML = `<div class="col-span-full text-center py-12 text-sm text-red-500">${escapeHtml(err.message || String(err))}</div>`;
    }
  }

  function renderMonitors(monitors) {
    const grid = document.getElementById("monitor-grid");
    const updated = document.getElementById("monitor-updated");
    if (!grid) return;

    if (!monitors || monitors.length === 0) {
      grid.innerHTML = `<div class="col-span-full text-center py-12 text-sm text-foreground/40">暂无监控</div>`;
      return;
    }

    grid.innerHTML = monitors.map(m => {
      const st = STATUS_MAP[m.status] || STATUS_MAP[0];
      const ratio = parseFloat(m.all_time_uptime_ratio || "0").toFixed(2);

      let responseTime = "-";
      if (m.average_response_time != null && m.average_response_time > 0) {
        responseTime = m.average_response_time;
      } else {
        const avg = computeAvgResponseTime(m.response_times);
        if (avg != null) responseTime = avg;
      }

      const dailyRatios = parseDailyRatios(m.custom_uptime_ranges);
      while (dailyRatios.length < STATUS_DAYS) dailyRatios.unshift(undefined);
      const { dates } = getDateRanges();

      return `
        <div class="rounded-xl border border-border/50 p-4 transition hover:border-border/80">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <h3 class="text-sm font-medium text-foreground truncate">${escapeHtml(m.friendly_name)}</h3>
            </div>
            <span class="shrink-0 flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[0.7rem] font-medium status-badge"
              style="background:${st.bg};color:${st.color}">
              <span class="status-dot" style="background:${st.color}"></span>
              ${st.label}
            </span>
          </div>
          <div class="flex gap-4 mt-3 text-xs text-foreground/50">
            <span>可用率 <strong class="text-foreground/80">${ratio}%</strong></span>
            <span>响应 <strong class="text-foreground/80">${responseTime} ms</strong></span>
          </div>
          <div class="flex gap-0.5 mt-4 w-full">
            ${dailyRatios.map((pct, i) => `<span class="flex-1 h-5 rounded-sm status-bar" style="background:${dayColor(pct)}" title="${dayTitle(dates[i] || 0, pct, m.status)}"></span>`).join("")}
          </div>
        </div>`;
    }).join("");

    if (updated) updated.textContent = `更新于 ${new Date().toLocaleTimeString("zh-CN", { hour12: false })}`;
  }

  function escapeHtml(text) {
    if (!text) return "";
    const d = document.createElement("div");
    d.textContent = text;
    return d.innerHTML;
  }

  document.addEventListener("astro:page-load", () => {
    if (document.getElementById("uptime-monitors")) {
      fetchMonitors();
      setInterval(fetchMonitors, 60000);
    }
  });
</script>

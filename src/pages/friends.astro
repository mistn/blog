---
import SiteTopbar from "@/components/SiteTopbar.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import PageHeader from "@/components/PageHeader.astro";
import Layout from "@/layouts/Layout.astro";
import { Code } from "astro-expressive-code/components";
import { defaultFriendAvatar, friendLinks, siteProfile } from "@/data/friends";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "zh";
const copy = ui[locale];
const applicationFields = [
  { label: "name", value: "miuo's blog" },
  { label: "url", value: siteProfile.href },
  { label: "avatar", value: siteProfile.avatar },
  { label: "desc", value: SITE.desc },
];
const applicationText = applicationFields
  .map(field => `${field.label}: ${field.value}`)
  .join("\n");
---

<Layout
  title={`${copy.pages.friendsTitle} | ${SITE.title}`}
  description={copy.pages.friendsDesc}
  structuredDataType="CollectionPage"
  structuredData={{
    mainEntity: {
      "@type": "ItemList",
      name: copy.pages.friendsTitle,
      numberOfItems: friendLinks.length,
    },
  }}
  {locale}
>
  <SiteTopbar />

  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 sm:px-6 pt-6 pb-10 md:pt-10 md:pb-14 overflow-x-hidden">
    <PageHeader title={copy.pages.friendsTitle} />
    <section class="py-4" data-pagefind-body>
      <div class="max-w-4xl">
        <section>
          {
            friendLinks.length > 0 ? (
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 sm:gap-4">
                {friendLinks.map(friend => (
                  <a
                    href={friend.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group flex items-center gap-3 rounded-xl border border-gray-100/60 dark:border-gray-800/60 p-3.5 text-left transition-all duration-200 ease-out active:scale-[0.98] active:bg-gray-50 dark:active:bg-gray-800/50 md:hover:-translate-y-1 md:hover:bg-gray-50/60 dark:md:hover:bg-gray-800/30 md:hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] dark:md:hover:shadow-[0_8px_30px_rgba(0,0,0,0.2)] sm:flex-col sm:items-center sm:gap-0 sm:p-4 sm:text-center"
                  >
                    <img
                      src={friend.avatar ?? defaultFriendAvatar}
                      alt={`${friend.name} avatar`}
                      class="h-12 w-12 shrink-0 rounded-full object-cover ring-1 ring-border/30 transition-transform duration-500 ease-out group-hover:scale-105 sm:mb-2.5"
                      loading="lazy"
                    />
                    <div class="min-w-0 flex flex-col justify-center sm:w-full sm:items-center">
                      <h2 class="line-clamp-1 text-sm font-semibold leading-snug text-foreground transition-colors duration-300 group-hover:text-accent">{friend.blog ?? friend.name}</h2>
                      {
                        friend.blog && friend.blog !== friend.name && (
                          <p class="mt-1 text-[0.7rem] leading-tight text-foreground/40">{friend.name}</p>
                        )
                      }
                      <p class="mt-1.5 line-clamp-2 text-xs leading-snug text-foreground/40">{friend.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            ) : (
              <div class="border-y border-border/65 py-8">
                <p class="text-[1.05rem] leading-8 text-foreground/68">
                  杩欓噷鏆傛椂杩樻病鏈夊弸閾俱€備氦鎹㈠畬鎴愬悗浼氬垪鍦ㄨ繖閲屻€?
                </p>
              </div>
            )
          }
        </section>

        <section class="apply-section">
          <div>
            <p class="section-eyebrow">Apply</p>
            <h2>友链申请条件</h2>
            <ul class="friend-requirements">
              <li>至少有 5 篇原创文章，无明显商业化内容</li>
              <li>域名注册超过 3 个月</li>
              <li>申请前请先添加本站友链</li>
            </ul>
          </div>

          <div class="friend-howto">
            <p class="friend-howto-title">申请方式</p>
            <p>
              页面底部评论区按格式留言，或发邮件到 <a href="mailto:hi@miuo.me" class="text-accent hover:underline">hi@miuo.me</a>。
            </p>
          </div>

          <div class="friend-application">
            <p class="friend-application-title">申请模板</p>
            <Code code={applicationText} lang="yaml" />
          </div>
        </section>
      </div>

      <div class="max-w-4xl">
        <ArtalkComments pageKey="/friends" pageTitle={copy.pages.friendsTitle} />
      </div>
    </section>
  </main>

</Layout>

<style>
  .apply-section {
    margin-top: 2.6rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    padding-top: 2.6rem;
  }

  .section-eyebrow {
    color: color-mix(in srgb, var(--foreground) 52%, transparent);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  .apply-section h2 {
    margin-top: 0.75rem;
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.18;
  }

  .apply-section p:not(.section-eyebrow) {
    max-width: 42rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    font-size: 1rem;
    line-height: 2;
  }

  .friend-application {
    position: relative;
  }

  .friend-requirements {
    list-style: disc;
    padding-left: 1.25rem;
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    font-size: 1rem;
    line-height: 2.2;
  }

  .friend-howto {
    margin-top: 1.8rem;
  }

  .friend-howto-title {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 88%, transparent);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .friend-howto p {
    max-width: 42rem;
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    font-size: 1rem;
    line-height: 2;
  }

  .friend-application-title {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 88%, transparent);
    font-size: 0.9rem;
    font-weight: 600;
  }


  @media (max-width: 639px) {
    .apply-section {
      margin-top: 2rem;
      padding-top: 2rem;
    }

    .apply-section h2 {
      font-size: 1.55rem;
    }

    .friend-application-title {
      font-size: 0.82rem;
    }
  }
</style>

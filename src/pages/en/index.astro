---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath } from "@/i18n";

const posts = await getCollection("blog");
const locale = getLocaleFromPath(Astro.url.pathname);
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const listPosts = recentPosts.slice(0, SITE.postPerPage);
const totalPages = Math.ceil(recentPosts.length / SITE.postPerPage);
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<Layout>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="mx-auto w-full max-w-4xl px-5 sm:px-6 pt-4 pb-10 md:pt-6 md:pb-14"
  >
    <section class="overflow-hidden">
      <div class="py-1.5 md:py-4">
        <div>
          <div class="min-w-0">
            <div data-post-list>
              {
                listPosts.map(post => {

                  return (
                  <article class="py-8 md:py-12" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.45rem] leading-tight font-medium tracking-tight transition hover:text-accent active:opacity-60"
                    >
                      {post.data.title}
                    </a>
                    <div class="mt-2.5 md:mt-3.5 flex flex-wrap items-center gap-2.5 text-xs text-foreground/60 [&_svg]:scale-75 [&_svg]:opacity-70">
                      <Datetime {...post.data} {locale} class="" />

                    </div>
                    <p class="mt-2 md:mt-3 max-w-3xl text-sm leading-relaxed text-gray-600 dark:text-gray-400 md:text-base line-clamp-2">
                      {post.data.description}
                    </p>
                  </article>
                  );
                })
              }
            </div>
            {totalPages > 1 && (
              <nav class="mt-4 md:mt-8 flex justify-center items-center gap-6" aria-label="Pagination Navigation">
                {pageNumbers.map(pageNumber => (
                  <a
                    href={
                      pageNumber === 1
                        ? localizePath("/", locale)
                        : localizePath(`/posts/${pageNumber}`, locale)
                    }
                    class={
                      pageNumber === 1
                        ? "text-gray-800 dark:text-gray-200 font-semibold text-base"
                        : "text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-100 transition-colors text-base"
                    }
                    aria-current={pageNumber === 1 ? "page" : undefined}
                  >
                    {pageNumber}
                  </a>
                ))}
              </nav>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", window.location.pathname);
    }
  });
</script>

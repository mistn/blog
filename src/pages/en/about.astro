---
import SiteTopbar from "@/components/SiteTopbar.astro";
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { SITE } from "@/config";
import { ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
---

<Layout title={`${copy.pages.aboutTitle} | ${SITE.title}`} description={copy.pages.aboutDesc} {locale}>
  <SiteTopbar />
  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 sm:px-6 pt-6 pb-10 md:pt-10 md:pb-14">
    <PageHeader title={copy.pages.aboutTitle} />
    <section
      id="about"
      class="app-prose prose-img:border-0"
    >
      <p>This is miuo's personal blog.</p>

      <p>
        Mostly technical notes, tinkering logs, and personal workflow setups.
        Written as reminders for myself. If something here happens to help you
        too, all the better. Source on <a href="https://github.com/mistn/blog">GitHub</a>.
      </p>

      <a href="/en/posts/windows-software-settings/" class="group flex items-center gap-3 rounded-xl border border-dashed border-gray-300 dark:border-gray-600 p-3.5 text-left no-underline transition-all duration-200 ease-out active:scale-[0.98] active:bg-gray-50 dark:active:bg-gray-800/50 md:hover:-translate-y-1 md:hover:bg-gray-50/60 dark:md:hover:bg-gray-800/30 md:hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] dark:md:hover:shadow-[0_8px_30px_rgba(0,0,0,0.2)] max-w-xs">
        <span class="h-10 w-10 shrink-0 rounded-lg ring-1 ring-border/30 flex items-center justify-center transition-transform duration-500 ease-out group-hover:scale-105 text-foreground/40">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>
        </span>
        <span class="min-w-0 flex flex-col justify-center">
          <span class="line-clamp-1 text-sm font-semibold leading-snug text-foreground transition-colors duration-300 group-hover:text-accent">Windows Software &amp; Settings</span>
          <span class="mt-1 line-clamp-1 text-xs leading-snug text-foreground/40">Software · Environment Config</span>
        </span>
      </a>

      <h2>Contact</h2>

      <ul>
        <li>Email: <a href="mailto:miuobox@gmail.com">miuobox@gmail.com</a></li>
        <li>Telegram: <a href="https://t.me/hacu0">@hacu0</a></li>
      </ul>
    </section>
  </main>
</Layout>

---
import DinoGame from "@/components/DinoGame.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { localizePath, ui } from "@/i18n";

const locale = "en";
const copy = ui[locale];
---

<Layout title={`404 ${copy.pages.notFoundTitle} | ${SITE.title}`} description={copy.pages.notFoundDesc} {locale}>
  <main
    id="main-content"
    class="app-layout min-h-[80vh] flex flex-col items-center justify-center"
  >
    <div class="flex flex-col items-center text-center">
      <DinoGame />
      <p class="text-6xl sm:text-7xl font-black leading-none text-accent select-none mt-2">
        404
      </p>
      <p class="mt-3 text-lg font-medium text-foreground/80">
        {copy.pages.notFoundTitle}
      </p>
      <p class="mt-1.5 max-w-sm text-sm text-foreground/40 leading-relaxed">
        {copy.pages.notFoundDesc}
      </p>
      <a
        href={localizePath("/", locale)}
        class="mt-6 inline-flex items-center gap-1.5 rounded-xl bg-accent px-5 py-2 text-sm font-medium text-white transition hover:opacity-85"
      >
        {copy.pages.notFoundCta}
      </a>
    </div>
  </main>

</Layout>

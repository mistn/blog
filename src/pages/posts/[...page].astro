---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui } from "@/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const listPosts = page.data;

const buildPageUrl = (n: number) =>
  n === 1 ? localizePath("/", locale) : localizePath(`/posts/${n}`, locale);
---

<Layout title={`${copy.pages.postsTitle} | ${SITE.title}`} description={copy.pages.postsDesc}>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    data-post-memory-scope="list"
    class="mx-auto w-full max-w-4xl px-4 sm:px-6 pt-6 pb-10 md:pt-10 md:pb-14"
  >
    <section class="overflow-hidden">
      <div class="px-1 py-2 sm:px-2 md:py-5">
        <div>
          <div class="min-w-0">
            <div data-post-list>
              {
                listPosts.map(post => {

                  return (
                  <article class="py-6 md:py-10" data-post-item>
                    <a
                      href={localizePath(getPath(post.id, post.filePath), locale)}
                      data-post-link
                      class="card-link-press inline-block text-[1.45rem] leading-tight font-medium tracking-tight transition hover:text-accent active:opacity-60"
                    >
                      {post.data.title}
                    </a>
                    <div class="mt-2.5 md:mt-3.5 flex flex-wrap items-center gap-2.5 text-xs text-foreground/60 [&_svg]:scale-75 [&_svg]:opacity-70">
                      <Datetime {...post.data} {locale} class="" />

                    </div>
                    <p class="mt-3 md:mt-4 max-w-3xl text-sm leading-relaxed text-gray-600 dark:text-gray-400 md:text-base line-clamp-2">
                      {post.data.description}
                    </p>
                  </article>
                  );
                })
              }
            </div>

            <Pagination currentPage={page.currentPage} lastPage={page.lastPage} {buildPageUrl} {locale} />
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", window.location.pathname);
  });
</script>

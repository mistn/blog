---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Socials from "@/components/Socials.astro";
import Datetime from "@/components/Datetime.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const leadPost = recentPosts[0];
const listPosts = recentPosts.slice(1, SITE.postPerIndex + 2);
const sidebarPosts = recentPosts.slice(0, 5);
---

<Layout>
  <SiteTopbar />
  <main
    id="main-content"
    data-layout="index"
    transition:name="page-body"
    class="app-layout pb-6 lg:max-w-7xl lg:pb-8"
  >
    <section class="relative overflow-hidden bg-[#f7f3eb] dark:bg-[#262b3a]">
      <div
        aria-hidden="true"
        class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(123,167,214,0.18),transparent_38%),linear-gradient(180deg,rgba(255,255,255,0.84),rgba(255,255,255,0.92))] dark:bg-[radial-gradient(circle_at_top,rgba(88,122,170,0.12),transparent_34%),linear-gradient(180deg,rgba(38,43,58,0.88),rgba(38,43,58,0.94))]"
      >
      </div>

      <div class="relative p-5 sm:p-6 lg:p-8">
        <div class="grid gap-5 lg:grid-cols-[minmax(0,1.65fr)_300px]">
          <div class="space-y-5">
            {
              leadPost && (
                <article class="relative overflow-hidden rounded-[1.6rem] border border-black/6 bg-[#dce8f8]/88 px-6 py-6 shadow-[0_12px_32px_rgba(15,23,42,0.05)] dark:border-white/8 dark:bg-[#31415d]/58 sm:px-7">
                  <div class="absolute top-5 left-5 h-11 w-11 overflow-hidden rounded-full border border-white/70 shadow-[0_4px_12px_rgba(15,23,42,0.10)]">
                    <img src="/avatar.avif" alt="avatar" class="h-full w-full object-cover" loading="eager" />
                  </div>
                  <div class="pl-16">
                    <a
                      href={getPath(leadPost.id, leadPost.filePath)}
                      class="card-link-press block text-[2rem] leading-tight font-semibold tracking-tight transition hover:text-accent sm:text-[2.45rem]"
                    >
                      {leadPost.data.title}
                    </a>
                    <Datetime {...leadPost.data} class="mt-4 text-foreground/60 [&_svg]:scale-75 [&_svg]:opacity-70" />
                    <p class="mt-5 max-w-3xl text-[1.05rem] leading-9 text-foreground/82">
                      {leadPost.data.description}
                    </p>
                    <div class="mt-7">
                      <a
                        href={getPath(leadPost.id, leadPost.filePath)}
                        class="card-link-press inline-flex items-center border-b border-current pb-1 text-base text-accent transition hover:opacity-70"
                      >
                        阅读剩余部分
                      </a>
                    </div>
                  </div>
                </article>
              )
            }

            {
              listPosts.map(post => (
                <article class="relative overflow-hidden rounded-[1.55rem] border border-black/6 bg-background/86 px-6 py-6 shadow-[0_10px_28px_rgba(15,23,42,0.04)] dark:border-white/8 sm:px-7">
                  <div class="absolute top-5 left-5 h-10 w-10 overflow-hidden rounded-full border border-border shadow-[0_4px_12px_rgba(15,23,42,0.08)]">
                    <img src="/avatar.avif" alt="avatar" class="h-full w-full object-cover" loading="eager" />
                  </div>
                  <div class="pl-15">
                    <a
                      href={getPath(post.id, post.filePath)}
                      class="card-link-press block text-[1.75rem] leading-tight font-semibold tracking-tight transition hover:text-accent sm:text-[1.95rem]"
                    >
                      {post.data.title}
                    </a>
                    <Datetime {...post.data} class="mt-3 text-foreground/58 [&_svg]:scale-75 [&_svg]:opacity-70" />
                    <p class="mt-4 max-w-3xl text-[1rem] leading-8 text-foreground/76">
                      {post.data.description}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>

          <aside class="space-y-5">
            <section class="rounded-[1.55rem] border border-black/6 bg-background/84 p-6 shadow-[0_10px_28px_rgba(15,23,42,0.04)] dark:border-white/8">
              <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">Contact</div>
              <div class="mt-5">
                <Socials />
              </div>
            </section>

            <section class="rounded-[1.55rem] border border-black/6 bg-background/84 p-6 shadow-[0_10px_28px_rgba(15,23,42,0.04)] dark:border-white/8">
              <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">Site Status</div>
              <div class="mt-5 space-y-3 text-[1rem] leading-7">
                <div class="flex items-center justify-between gap-4 border-b border-border/70 pb-3">
                  <span class="text-foreground/62">Posts</span>
                  <span class="font-semibold">{sortedPosts.length}</span>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <span class="text-foreground/62">Recent</span>
                  <span class="font-semibold">{SITE.postPerIndex}</span>
                </div>
              </div>
            </section>

            <section class="rounded-[1.55rem] border border-black/6 bg-[#f2c8d7]/78 p-6 shadow-[0_10px_28px_rgba(15,23,42,0.04)] dark:border-white/8 dark:bg-[#5b4150]/60">
              <div class="text-[11px] uppercase tracking-[0.28em] text-foreground/50">Latest Titles</div>
              <ul class="mt-5 space-y-4">
                {
                  sidebarPosts.map(post => (
                    <li class="border-b border-black/8 pb-4 last:border-b-0 last:pb-0 dark:border-white/10">
                      <a
                        href={getPath(post.id, post.filePath)}
                        class="block text-[1rem] leading-7 font-medium transition hover:text-accent"
                      >
                        {post.data.title}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </section>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

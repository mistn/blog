---
export const prerender = false;

const adminUser = process.env.ADMIN_USER || "admin";
const adminPass = process.env.ADMIN_PASS;

let error = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const user = formData.get("user")?.toString() || "";
  const pass = formData.get("pass")?.toString() || "";

  if (user === adminUser && pass === adminPass && adminPass) {
    const token = btoa(`${adminUser}:${adminPass}`);
    Astro.cookies.set("admin_token", token, {
      path: "/",
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7, // 7 days
    });
    return Astro.redirect("/keystatic");
  }

  error = "用户名或密码错误";
}
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>登录 - 管理后台</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-dvh flex items-center justify-center bg-zinc-50 dark:bg-zinc-900">
    <div class="w-full max-w-sm mx-auto px-6">
      <div class="text-center mb-8">
        <h1 class="text-xl font-medium text-zinc-900 dark:text-zinc-100">
          管理后台
        </h1>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
          请输入管理员密码
        </p>
      </div>

      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
            用户名
          </label>
          <input
            type="text"
            name="user"
            required
            autocomplete="username"
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
            placeholder="admin"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
            密码
          </label>
          <input
            type="password"
            name="pass"
            required
            autocomplete="current-password"
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-zinc-400 dark:focus:ring-zinc-500"
          />
        </div>

        {
          error && (
            <p class="text-sm text-red-500 dark:text-red-400 text-center">{error}</p>
          )
        }

        <button
          type="submit"
          class="w-full rounded-lg bg-zinc-900 dark:bg-zinc-100 px-4 py-2 text-sm font-medium text-white dark:text-zinc-900 hover:bg-zinc-800 dark:hover:bg-zinc-200 transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400"
        >
          登录
        </button>
      </form>
    </div>
  </body>
</html>

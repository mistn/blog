---
export const prerender = false;

import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";

const adminUser = process.env.ADMIN_USER || "admin";
const adminPass = process.env.ADMIN_PASS;

let error = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const user = formData.get("user")?.toString() || "";
  const pass = formData.get("pass")?.toString() || "";

  if (user === adminUser && pass === adminPass && adminPass) {
    const token = btoa(`${adminUser}:${adminPass}`);
    Astro.cookies.set("admin_token", token, {
      path: "/",
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: "lax",
      maxAge: 60 * 60 * 24 * 7,
    });
    return Astro.redirect("/keystatic");
  }

  error = "用户名或密码错误";
}
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>管理后台</title>
    <link rel="icon" type="image/avif" sizes="any" href="/favicon.avif?v=20260721" />
    <link rel="icon" type="image/png" href="/favicon.png?v=20260511" />
    <style>
      :root {
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans);
        color: #111;
        background-color: #fff;
        background-image:
          linear-gradient(rgba(47,98,143,0.10) 1px, transparent 1px),
          linear-gradient(90deg, rgba(47,98,143,0.10) 1px, transparent 1px),
          linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.96));
        background-size: 28px 28px, 28px 28px, auto;
        background-position: center top;
        background-repeat: repeat, repeat, no-repeat;
      }

      html[data-theme="dark"] body {
        color: #e7ebf1;
        background-color: #171d29;
        background-image:
          linear-gradient(rgba(141,182,255,0.13) 1px, transparent 1px),
          linear-gradient(90deg, rgba(141,182,255,0.13) 1px, transparent 1px),
          linear-gradient(180deg, rgba(23,29,41,0.97), rgba(23,29,41,0.97));
      }

      .toggle {
        position: fixed;
        top: 1.25rem;
        right: 1.25rem;
        width: 2.5rem;
        height: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        background: none;
        border-radius: 50%;
        color: rgba(0,0,0,0.5);
        transition: color 0.15s;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
      }
      html[data-theme="dark"] .toggle {
        color: rgba(255,255,255,0.6);
      }
      .toggle:hover { color: currentColor; }

      .toggle span {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 1.25rem;
        height: 1.25rem;
        transform: translate(-50%, -50%);
        pointer-events: none;
      }

      .toggle svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        transition: transform 0.35s ease, opacity 0.35s ease;
      }

      .toggle .moon {
        transform: scale(1) rotate(0deg);
        opacity: 1;
      }
      .toggle .sun {
        transform: scale(0) rotate(90deg);
        opacity: 0;
      }

      html[data-theme="dark"] .toggle .moon {
        transform: scale(0) rotate(-90deg);
        opacity: 0;
      }
      html[data-theme="dark"] .toggle .sun {
        transform: scale(1) rotate(0deg);
        opacity: 1;
      }

      .card {
        position: relative;
        width: 100%;
        max-width: 22rem;
        margin: 0 1.5rem;
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(0,0,0,0.12);
        border-radius: 1rem;
        padding: 2.5rem 2rem 2rem;
      }

      html[data-theme="dark"] .card {
        background: rgba(23,29,41,0.82);
        border-color: rgba(255,255,255,0.12);
      }

      .brand {
        text-align: center;
        margin-bottom: 1.75rem;
      }
      .brand h1 {
        font-size: 1.125rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .brand p {
        margin-top: 0.375rem;
        font-size: 0.8rem;
        opacity: 0.4;
        font-weight: 400;
      }

      .field {
        margin-bottom: 0.875rem;
      }
      .field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 500;
        opacity: 0.5;
        margin-bottom: 0.375rem;
      }
      .field input {
        width: 100%;
        padding: 0.55rem 0.75rem;
        font-size: 0.875rem;
        font-family: inherit;
        color: inherit;
        background: rgba(0,0,0,0.025);
        border: 1px solid rgba(0,0,0,0.12);
        border-radius: 0.5rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      html[data-theme="dark"] .field input {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.12);
      }
      .field input:focus {
        border-color: rgba(47,98,143,0.45);
        box-shadow: 0 0 0 3px rgba(47,98,143,0.12);
      }
      html[data-theme="dark"] .field input:focus {
        border-color: rgba(141,182,255,0.45);
        box-shadow: 0 0 0 3px rgba(141,182,255,0.12);
      }
      .field input::placeholder { opacity: 0.25; }

      .error {
        font-size: 0.75rem;
        color: #e5484d;
        text-align: center;
        margin-bottom: 0.75rem;
      }

      .btn {
        width: 100%;
        padding: 0.55rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        font-family: inherit;
        color: #fff;
        background: #111;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.25rem;
      }
      html[data-theme="dark"] .btn {
        color: #171d29;
        background: #e7ebf1;
      }
      .btn:hover { opacity: 0.8; }
    </style>
  </head>
  <body>
    <script is:inline>
      (function(){
        var t=localStorage.getItem("theme");
        if(t) document.firstElementChild.setAttribute("data-theme",t);
        else if(window.matchMedia("(prefers-color-scheme:dark)").matches) document.firstElementChild.setAttribute("data-theme","dark");
      })();
    </script>

    <button class="toggle" id="toggle" aria-label="切换主题">
      <span aria-hidden="true">
        <IconMoon class="moon" />
        <IconSunHigh class="sun" />
      </span>
    </button>

    <div class="card">
      <div class="brand">
        <h1>管理后台</h1>
        <p>验证身份以继续</p>
      </div>

      <form method="POST">
        <div class="field">
          <label for="user">用户名</label>
          <input id="user" type="text" name="user" required autocomplete="username" placeholder="admin" />
        </div>
        <div class="field">
          <label for="pass">密码</label>
          <input id="pass" type="password" name="pass" required autocomplete="current-password" />
        </div>

        {error && <p class="error">{error}</p>}

        <button type="submit" class="btn">登录</button>
      </form>
    </div>

    <script is:inline>
      document.getElementById("toggle").onclick = function(){
        var el = document.firstElementChild;
        var next = el.getAttribute("data-theme") === "dark" ? "light" : "dark";
        el.setAttribute("data-theme", next);
        localStorage.setItem("theme", next);
      };
    </script>
  </body>
</html>

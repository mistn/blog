---
interface Props {
  locale?: string;
}

const { locale = "zh" } = Astro.props;
const isZh = locale === "zh";

const title = isZh ? "Anki 学习" : "Anki Learning";
const loadingText = isZh ? "加载中..." : "Loading...";

const labels = {
  today: isZh ? "今日进度" : "Today's Progress",
  updated: isZh ? "更新于" : "Updated",
  new: isZh ? "新词" : "New",
  study: isZh ? "学习" : "Study",
  min: isZh ? "分钟" : "min",
  source: isZh ? "数据来自 GitHub Gist" : "Data from GitHub Gist",
};
---

<section
  data-anki-locale={locale}
  data-anki-labels={JSON.stringify(labels)}
>
  <h2 class="text-lg font-semibold text-foreground mb-6">{title}</h2>
  <div id="anki-panel">
    <div class="rounded-2xl border border-border/40 bg-background/50 backdrop-blur-sm p-4 sm:p-5">
      <div class="flex items-center justify-center py-10 text-sm text-foreground/40 gap-2">
        <svg class="size-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
        {loadingText}
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-anki-locale]')!;
  const LOCALE: string = root.dataset.ankiLocale!;
  const L: Record<string, string> = JSON.parse(root.dataset.ankiLabels!);
  const FMT = LOCALE === 'zh' ? 'zh-CN' : 'en-US';

  function escapeHtml(text: string): string {
    if (!text) return '';
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }

  async function fetchAnkiStats() {
    const panel = document.getElementById('anki-panel');
    if (!panel) return;
    try {
      const res = await fetch('/api/anki-stats');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      renderAnki(data);
    } catch (err) {
      panel.innerHTML = `<div class="rounded-2xl border border-border/40 bg-background/50 p-4 sm:p-5"><div class="text-center py-8 text-sm text-red-500">${escapeHtml((err as Error).message || String(err))}</div></div>`;
    }
  }

  function renderAnki(data: any) {
    const panel = document.getElementById('anki-panel');
    if (!panel) return;

    const learned: number = data.today_learned || 0;
    const total: number = data.today_total || 0;
    const mins: number = data.duration_minutes || 0;
    const updated = data.last_updated
      ? new Date(data.last_updated).toLocaleString(FMT, { hour12: false })
      : '---';

    panel.innerHTML = `
      <div class="rounded-2xl border border-border/40 bg-background/50 backdrop-blur-sm p-3.5 sm:p-4 transition-all duration-300 hover:border-border/60 hover:shadow-lg hover:shadow-foreground/[0.03]">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-2">
            <span class="inline-flex size-2 rounded-full bg-emerald-400 shadow-[0_0_6px] shadow-emerald-400/30"></span>
            <h3 class="text-sm font-semibold text-foreground">${L.today}</h3>
          </div>
          <span class="text-[0.65rem] text-foreground/35 font-mono tabular-nums">${L.updated} ${updated}</span>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-xl bg-emerald-500/5 border border-emerald-500/10 px-3.5 py-2.5">
            <span class="text-[0.65rem] text-foreground/40 uppercase tracking-wider font-medium">${L.new}</span>
            <p class="text-lg font-bold text-foreground mt-0.5">${learned}</p>
          </div>
          <div class="rounded-xl bg-sky-500/5 border border-sky-500/10 px-3.5 py-2.5">
            <span class="text-[0.65rem] text-foreground/40 uppercase tracking-wider font-medium">${L.study}</span>
            <p class="text-lg font-bold text-foreground mt-0.5">${mins}<span class="text-sm font-normal text-foreground/25"> ${L.min}</span></p>
          </div>
        </div>
        <p class="mt-3 text-[0.65rem] text-foreground/25">${L.source}</p>
      </div>`;
  }

  document.addEventListener('astro:page-load', () => {
    if (document.getElementById('anki-panel')) {
      fetchAnkiStats();
      setInterval(fetchAnkiStats, 300000);
    }
  });
</script>

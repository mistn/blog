---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3" | "home";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
const isHome = Heading === "home";
const HeadingTag = isHome ? "h2" : Heading;
---

<li class:list={[isHome ? "group border-b border-border/80 py-7 last:border-b-0 last:pb-0 first:pt-0" : "my-6"]}>
  <a
    href={getPath(id, filePath)}
    class:list={[
      isHome
        ? "inline-block text-[1.45rem] leading-tight font-semibold tracking-tight text-foreground transition group-hover:text-accent"
        : "inline-block text-lg font-medium text-accent",
      isHome
        ? "decoration-dashed underline-offset-4"
        : "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <HeadingTag
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </HeadingTag>
  </a>
  <Datetime
    {...props}
    class:list={[
      isHome ? "mt-3 text-foreground/55 [&_svg]:scale-75 [&_svg]:opacity-70" : "",
    ]}
  />
  <p class:list={[isHome ? "mt-3 max-w-3xl text-[1rem] leading-8 text-foreground/72" : ""]}>
    {description}
  </p>
</li>

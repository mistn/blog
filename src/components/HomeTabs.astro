---
import { getLocaleFromPath, localizePath, normalizePath, ui } from "@/i18n";

const { pathname } = Astro.url;
const locale = getLocaleFromPath(pathname);
const copy = ui[locale];
const currentPath = normalizePath(pathname);
const getHref = (path: string) => localizePath(path, locale);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));
const isChildActive = (paths: string[]) =>
  paths.some(
    p => currentPath === normalizePath(getHref(p)) || currentPath.startsWith(normalizePath(getHref(p)) + "/")
  );

const tabClass =
  "home-tab inline-flex items-center px-2 py-1 text-lg font-semibold text-foreground/85 relative cursor-pointer";
const activeTabClass =
  "text-foreground";

const underlineClass =
  "after:absolute after:-bottom-0.5 after:left-0 after:h-[2px] after:w-0 after:bg-black dark:after:bg-white after:transition-[width] after:duration-200 after:content-['']";
const activeUnderlineClass =
  "after:w-full";

const subTabClass =
  "flex items-center px-4 py-2 text-sm text-foreground/85 transition whitespace-nowrap w-full hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black";
const activeSubClass =
  "bg-black text-white dark:bg-white dark:text-black";

const articlesChildren = ["/archives", "/weekly"];
const aboutChildren = ["/about", "/tools"];
---

<nav
  data-home-tabs
  class="flex min-w-0 items-center gap-x-6 whitespace-nowrap text-sm"
>
  <a href={getHref("/")}
    data-path={getHref("/")}
    class:list={[tabClass, underlineClass, { [activeTabClass]: isActive("/"), [activeUnderlineClass]: isActive("/") }]}
  >
    {copy.nav.home}
  </a>

  <div class="relative group" data-dropdown="articles">
    <button
      data-dropdown-trigger
      class:list={[
        tabClass,
        underlineClass,
        "cursor-pointer",
        { [activeTabClass]: !isActive("/") && isChildActive(articlesChildren), [activeUnderlineClass]: !isActive("/") && isChildActive(articlesChildren) },
      ]}
    >
      {copy.nav.articles}
      <svg class="ml-1 size-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" data-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </button>
    <div
      data-dropdown-menu
      class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible scale-y-0 origin-top transition-all duration-150 z-50 group-hover:opacity-100 group-hover:visible group-hover:scale-y-100 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:scale-y-100"
    >
      <div class="min-w-max border border-black dark:border-white bg-background py-1">
        <a
          href={getHref("/archives")}
          data-path={getHref("/archives")}
          class:list={[subTabClass, { [activeSubClass]: isActive("/archives") }]}
        >
          {copy.nav.archives}
        </a>
        <a
          href={getHref("/weekly")}
          data-path={getHref("/weekly")}
          class:list={[subTabClass, { [activeSubClass]: isChildActive(["/weekly"]) }]}
        >
          {copy.nav.weekly}
        </a>
      </div>
    </div>
  </div>

  <a href={getHref("/anime")}
    data-path={getHref("/anime")}
    class:list={[tabClass, underlineClass, { [activeTabClass]: isActive("/anime"), [activeUnderlineClass]: isActive("/anime") }]}
  >
    {copy.nav.anime}
  </a>

  <a href={getHref("/friends")}
    data-path={getHref("/friends")}
    class:list={[tabClass, underlineClass, { [activeTabClass]: isActive("/friends"), [activeUnderlineClass]: isActive("/friends") }]}
  >
    {copy.nav.friends}
  </a>

  <div class="relative group" data-dropdown="about">
    <button
      data-dropdown-trigger
      class:list={[
        tabClass,
        underlineClass,
        "cursor-pointer",
        { [activeTabClass]: !isActive("/") && isChildActive(aboutChildren), [activeUnderlineClass]: !isActive("/") && isChildActive(aboutChildren) },
      ]}
    >
      {copy.nav.about}
      <svg class="ml-1 size-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" data-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </button>
    <div
      data-dropdown-menu
      class="absolute left-1/2 -translate-x-1/2 top-full pt-3 opacity-0 invisible scale-y-0 origin-top transition-all duration-150 z-50 group-hover:opacity-100 group-hover:visible group-hover:scale-y-100 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:scale-y-100"
    >
      <div class="min-w-max border border-black dark:border-white bg-background py-1">
        <a
          href={getHref("/tools")}
          data-path={getHref("/tools")}
          class:list={[subTabClass, { [activeSubClass]: isActive("/tools") }]}
        >
          {copy.nav.tools}
        </a>
        <a
          href={getHref("/about")}
          data-path={getHref("/about")}
          class:list={[subTabClass, { [activeSubClass]: isActive("/about") }]}
        >
          {copy.nav.aboutMe}
        </a>
      </div>
    </div>
  </div>
</nav>

<style is:global>
  .home-tab {
    background-image: linear-gradient(to right, #000, #000);
    background-repeat: no-repeat;
    background-size: 0% 100%;
    background-position: 0 0;
    transition: background-size 0.2s ease-out, color 0.2s ease-out;
  }
  .home-tab:hover {
    background-size: 100% 100%;
    color: #fff;
  }
  .home-tab:hover [data-chevron] {
    color: #fff;
  }
  [data-theme="dark"] .home-tab {
    background-image: linear-gradient(to right, #fff, #fff);
  }
  [data-theme="dark"] .home-tab:hover {
    color: #000;
  }
  [data-theme="dark"] .home-tab:hover [data-chevron] {
    color: #000;
  }
</style>

<script is:inline>
  const ACTIVE_UNDERLINE = "after:w-full";
  const ACTIVE_CLASSES = ["text-foreground"];

  function normalizePath(path) {
    if (!path) return "/";
    return path.endsWith("/") && path !== "/" ? path.slice(0, -1) : path;
  }

  function syncHomeTabs() {
    const currentPath = normalizePath(window.location.pathname);

    document.querySelectorAll("[data-home-tabs] [data-path]").forEach(tab => {
      const target = normalizePath(tab.getAttribute("data-path"));
      const isActive = target === currentPath;
      ACTIVE_CLASSES.forEach(c => tab.classList.toggle(c, isActive));
      tab.classList.toggle(ACTIVE_UNDERLINE, isActive);
    });

    document.querySelectorAll("[data-dropdown]").forEach(dropdown => {
      const btn = dropdown.querySelector("[data-dropdown-trigger]");
      const children = dropdown.querySelectorAll("[data-path]");
      let anyActive = false;
      children.forEach(child => {
        const target = normalizePath(child.getAttribute("data-path"));
        if (target === currentPath || currentPath.startsWith(target + "/")) {
          anyActive = true;
        }
      });
      if (btn) {
        ACTIVE_CLASSES.forEach(c => btn.classList.toggle(c, anyActive));
        btn.classList.toggle(ACTIVE_UNDERLINE, anyActive);
      }
    });
  }

  document.addEventListener("astro:page-load", syncHomeTabs);
  syncHomeTabs();
</script>

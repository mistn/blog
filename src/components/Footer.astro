---
import type { HTMLAttributes } from "astro/types";
import { SITE } from "@/config";

const currentYear = new Date().getFullYear();

type Props = HTMLAttributes<"footer">;

const { class: className, ...attrs } = Astro.props;

const displayYear = currentYear;
---

<footer
  class:list={["app-layout mt-auto", className]}
  {...attrs}
>
  <div
    class:list={[
      "pt-10 md:pt-20 pb-6",
      "flex justify-center",
    ]}
  >
    <div
      class="my-2 flex flex-col items-center text-xs whitespace-nowrap text-gray-400 dark:text-gray-500 sm:flex-row"
    >
      <span>&#169; {displayYear} {SITE.author}</span>
      <a
        class="mt-1 hover:text-gray-600 dark:hover:text-gray-300 sm:ml-3 sm:mt-0"
        href="https://icp.gov.moe/?keyword=20260260"
        target="_blank"
        rel="noopener noreferrer"
      >
        萌ICP备20260260号
      </a>
    </div>
  </div>
</footer>

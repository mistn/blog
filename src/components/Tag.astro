---
import { getLocaleFromPath, localizePath, type Locale } from "@/i18n";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  locale?: Locale;
  count?: number;
};

const {
  tag,
  tagName,
  size = "lg",
  locale = getLocaleFromPath(Astro.url.pathname),
  count,
} = Astro.props;
---

<li class="relative">
  <a
    href={localizePath(`/tags/${tag}/`, locale)}
    class:list={[
      "group inline-flex items-center gap-1 border-b border-transparent text-foreground/64 no-underline transition-colors",
      "hover:border-accent/45 hover:text-accent",
      "focus-visible:border-accent/55 focus-visible:text-accent",
      { "px-0.5 py-0.5 text-sm": size === "sm" },
      { "px-0.5 py-1 text-base": size === "lg" },
    ]}
  >
    {tagName}
  </a>
  {count !== undefined && count > 1 && (
    <span class="absolute -top-2 -right-3 flex min-w-4 items-center justify-center px-1 text-[10px] leading-none text-foreground/45">
      {count}
    </span>
  )}
</li>

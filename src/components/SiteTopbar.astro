---
import LinkButton from "@/components/LinkButton.astro";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";
---

<section transition:persist class="app-layout py-6 lg:max-w-7xl lg:py-8">
  <div class="relative border-b border-border/70 px-1 pb-6 sm:px-2">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 h-full bg-[radial-gradient(circle_at_top,rgba(123,167,214,0.14),transparent_44%)] dark:bg-[radial-gradient(circle_at_top,rgba(88,122,170,0.12),transparent_40%)]"
    >
    </div>

    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="flex items-start gap-4">
        <div class="h-18 w-18 overflow-hidden rounded-full border border-border/80 shadow-[0_6px_18px_rgba(15,23,42,0.04)] sm:h-20 sm:w-20">
          <img
            src="/avatar.avif"
            alt={`${SITE.author} avatar`}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">{SITE.title}</p>
          <a
            href="/about"
            class="mt-2 inline-block text-[2rem] leading-none font-semibold tracking-tight transition hover:text-accent"
          >
            {SITE.author}
          </a>
          <p class="mt-3 max-w-xl text-sm leading-7 text-foreground/70">{SITE.desc}</p>
        </div>
      </div>

      <div class="flex items-center gap-2 self-end lg:self-start">
        {SITE.showArchives && (
          <LinkButton
            href="/archives"
            class="focus-outline flex p-3 hover:[&>svg]:stroke-accent"
            title="Archives"
            aria-label="archives"
          >
            <IconArchive />
            <span class="sr-only">Archives</span>
          </LinkButton>
        )}
        <LinkButton
          href="/search"
          class="focus-outline flex p-3 hover:[&>svg]:stroke-accent"
          title="Search"
          aria-label="search"
        >
          <IconSearch />
          <span class="sr-only">Search</span>
        </LinkButton>
        {SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-12 p-3 hover:[&>svg]:stroke-accent"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )}
      </div>
    </div>
  </div>
</section>

---
import LinkButton from "@/components/LinkButton.astro";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import { SITE } from "@/config";

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const isActive = (path: string) => currentPath === path;
---

<section transition:persist class="app-layout py-6 lg:max-w-7xl lg:py-8">
  <div class="relative border-b border-border/70 px-1 pb-6 sm:px-2">
    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="flex items-start gap-4">
        <div class="h-18 w-18 overflow-hidden rounded-full border border-border/80 sm:h-20 sm:w-20">
          <img
            src="/avatar.avif"
            alt={`${SITE.author} avatar`}
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
        <div>
          <p class="text-[11px] uppercase tracking-[0.28em] text-foreground/45">{SITE.title}</p>
          <a
            href="/"
            class="mt-2 inline-block text-[2rem] leading-none font-semibold tracking-tight transition hover:text-accent"
          >
            {SITE.author}
          </a>
          <p class="mt-3 max-w-xl text-sm leading-7 text-foreground/70">{SITE.desc}</p>
          <nav class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-foreground/68">
            <a
              href="/"
              class:list={[
                "transition hover:text-accent",
                { "text-accent": isActive("/") },
              ]}
            >
              首页
            </a>
            {SITE.showArchives && (
              <a
                href="/archives"
                class:list={[
                  "transition hover:text-accent",
                  { "text-accent": isActive("/archives") },
                ]}
              >
                归档
              </a>
            )}
            <a
              href="/about"
              class:list={[
                "transition hover:text-accent",
                { "text-accent": isActive("/about") },
              ]}
            >
              关于
            </a>
          </nav>
        </div>
      </div>

      <div class="flex items-center gap-1 self-end lg:gap-2 lg:self-start">
        <LinkButton
          href="/search"
          class="focus-outline flex p-2.5 hover:[&>svg]:stroke-accent sm:p-3"
          title="Search"
          aria-label="search"
        >
          <IconSearch />
          <span class="sr-only">Search</span>
        </LinkButton>
        {SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline relative size-10 p-2.5 hover:[&>svg]:stroke-accent sm:size-12 sm:p-3"
            title="Toggles light & dark"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )}
      </div>
    </div>
  </div>
</section>

---
import IconMail from "@/assets/icons/IconMail.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import HomeTabs from "@/components/HomeTabs.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import {
  getAlternateLocale,
  getLocaleFromPath,
  localizePath,
  normalizePath,
  ui,
} from "@/i18n";

type Props = {
  compactMobile?: boolean;
};

const { compactMobile = false } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const alternateLocale = getAlternateLocale(locale);
const languageHref = localizePath(Astro.url.pathname, alternateLocale);
const emailLink = SOCIALS.find(social => social.href.startsWith("mailto:"));
const emailAddress = emailLink?.href.replace("mailto:", "");
const emailLabel = `${copy.nav.email} ${SITE.title}`;

const getHref = (path: string) => localizePath(path, locale);
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));
const isPathActive = (path: string) => currentPath.startsWith(normalizePath(getHref(path)) + "/");
---

<!-- ===== Header ===== -->
<header class="relative z-[70]">
<!-- ===== Topbar ===== -->
<section
  class:list={[
    "mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 lg:py-8",
    compactMobile ? "py-4" : "py-6",
  ]}
>
    <div
      class:list={[
        "font-app relative",
        compactMobile ? "pb-3" : "pb-4",
      ]}
    >
      <div class="flex items-center justify-between lg:grid lg:grid-cols-3">
        <!-- Left: Logo -->
        <div id="mobile-logo-area" class="min-w-0">
          <a href={getHref("/")} class="text-[1.85rem] leading-none font-medium tracking-tight no-underline text-foreground hover:text-foreground/80 transition-colors">
            {SITE.author}
          </a>
        </div>

        <!-- Center: Nav links (desktop) -->
        <div class="hidden lg:flex justify-self-center">
          <HomeTabs />
        </div>

        <!-- Right: Icons -->
        <div class="flex items-center gap-1 justify-self-end">
          <!-- Desktop icons -->
          <div class="hidden lg:flex items-center gap-4">
            <LinkButton
              href={localizePath("/search", locale)}
              class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
              title={copy.nav.search}
              aria-label={copy.nav.search}
            >
              <IconSearch class="size-5" />
              <span class="sr-only">{copy.nav.search}</span>
            </LinkButton>

            <a
              href="/rss.xml"
              class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
              title="RSS"
              aria-label="RSS"
            >
              <IconRss class="size-5" />
              <span class="sr-only">RSS</span>
            </a>

            <a
              href={languageHref}
              data-locale-target={alternateLocale}
              data-astro-reload
              class="group inline-flex size-10 items-center justify-center rounded-full text-foreground/68 transition focus-outline hover:text-accent"
              title={copy.nav.languageLabel}
              aria-label={copy.nav.languageLabel}
            >
              <IconLanguage class="size-5" />
              <span class="sr-only">{copy.nav.languageLabel}</span>
            </a>

            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn-desktop"
                  class="focus-outline relative size-10 rounded-full text-foreground/68 transition hover:text-accent"
                  title={copy.nav.theme}
                  aria-label={copy.nav.theme}
                  aria-live="polite"
                >
                  <span
                    data-theme-icon-anchor
                    class="pointer-events-none absolute top-[50%] left-[50%] size-5 -translate-[50%]"
                    aria-hidden="true"
                  >
                    <IconMoon class="absolute inset-0 h-full w-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                    <IconSunHigh class="absolute inset-0 h-full w-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                  </span>
                </button>
              )
            }
          </div>

          <!-- Mobile: search + theme + menu -->
          <div class="flex lg:hidden items-center gap-1">
          <span id="mobile-header-actions" class="contents">
            <a
              href={localizePath("/search", locale)}
              class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
              title={copy.nav.search}
              aria-label={copy.nav.search}
              data-menu-link
            >
              <IconSearch class="w-5 h-5" />
            </a>
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
                  title={copy.nav.theme}
                  aria-label={copy.nav.theme}
                  aria-live="polite"
                >
                  <span
                    data-theme-icon-anchor
                    class="pointer-events-none relative w-5 h-5"
                    aria-hidden="true"
                  >
                    <IconMoon class="absolute inset-0 w-full h-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                    <IconSunHigh class="absolute inset-0 w-full h-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                  </span>
                </button>
              )
            }
          </span>
          <button
            id="menu-toggle"
            class="group flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
            aria-label="Menu"
            aria-expanded="false"
          >
            <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out group-aria-expanded:rotate-90 group-aria-expanded:scale-50 group-aria-expanded:opacity-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
            <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out -rotate-90 scale-50 opacity-0 group-aria-expanded:rotate-0 group-aria-expanded:scale-100 group-aria-expanded:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
          </button>
          </div>   <!-- end mobile icons -->
        </div>     <!-- end right column -->
      </div>       <!-- end topbar row -->

      <!-- ===== Mobile Dropdown Card ===== -->
      <div
        id="mobile-dropdown"
        class="hidden absolute top-full right-0 mt-2 w-64 rounded-xl border border-border/40 shadow-xl z-50 origin-top-right"
        aria-hidden="true"
      >
        <nav class="py-2">
          <a
            href={getHref("/")}
            class:list={[
              "block px-4 py-4 text-sm text-left transition-colors",
              isActive("/")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.home}
          </a>
          <div class="mx-4 border-b border-border/40" aria-hidden="true"></div>
          <div class="px-4 py-3 text-xs font-semibold text-foreground/40 uppercase tracking-wider">
            {copy.nav.articles}
          </div>
          {
            SITE.showArchives && (
              <a
                href={getHref("/archives")}
                class:list={[
                  "block pl-8 pr-4 py-3 text-sm text-left transition-colors",
                  isActive("/archives")
                    ? "font-semibold text-foreground"
                    : "font-medium text-foreground/65 hover:text-foreground",
                ]}
                data-menu-link
              >
                {copy.nav.archives}
              </a>
            )
          }
          <a
            href={getHref("/weekly")}
            class:list={[
              "block pl-8 pr-4 py-3 text-sm text-left transition-colors",
              isActive("/weekly") || isPathActive("/weekly")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.weekly}
          </a>
          <div class="mx-4 border-b border-border/40" aria-hidden="true"></div>
          <a
            href={getHref("/anime")}
            class:list={[
              "block px-4 py-4 text-sm text-left transition-colors",
              isActive("/anime")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.anime}
          </a>
          <div class="mx-4 border-b border-border/40" aria-hidden="true"></div>
          <a
            href={getHref("/friends")}
            class:list={[
              "block px-4 py-4 text-sm text-left transition-colors",
              isActive("/friends")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.friends}
          </a>
          <div class="mx-4 border-b border-border/40" aria-hidden="true"></div>
          <div class="px-4 py-3 text-xs font-semibold text-foreground/40 uppercase tracking-wider">
            {copy.nav.about}
          </div>
          <a
            href={getHref("/about")}
            class:list={[
              "block pl-8 pr-4 py-3 text-sm text-left transition-colors",
              isActive("/about")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.aboutMe}
          </a>
          <a
            href={getHref("/tools")}
            class:list={[
              "block pl-8 pr-4 py-3 text-sm text-left transition-colors",
              isActive("/tools")
                ? "font-semibold text-foreground"
                : "font-medium text-foreground/65 hover:text-foreground",
            ]}
            data-menu-link
          >
            {copy.nav.tools}
          </a>
        </nav>

        <div class="border-t border-border/40" aria-hidden="true"></div>

        <div class="flex items-center justify-center gap-8 py-4 px-4">
          {
            emailLink && emailAddress && (
              <a
                href={emailLink.href}
                class="text-foreground/50 hover:text-foreground transition-colors"
                title={emailLabel}
                aria-label={emailLabel}
              >
                <IconMail class="size-5" />
              </a>
            )
          }
          <a
            href="/rss.xml"
            class="text-foreground/50 hover:text-foreground transition-colors"
            title="RSS"
            aria-label="RSS"
          >
            <IconRss class="size-5" />
          </a>
          <a
            href={languageHref}
            data-locale-target={alternateLocale}
            data-astro-reload
            class="text-foreground/50 hover:text-foreground transition-colors"
            title={copy.nav.languageLabel}
            aria-label={copy.nav.languageLabel}
          >
            <IconLanguage class="size-5" />
          </a>
        </div>
      </div>
    </div>
</section>
</header>

<!-- ===== Mobile Menu Overlay ===== -->
<div
  id="mobile-overlay"
  class="fixed inset-0 z-40 hidden opacity-0 transition-opacity duration-200 ease-out"
  aria-hidden="true"
></div>

<script is:inline>
  function getDropdown() { return document.getElementById("mobile-dropdown"); }
  function getOverlay() { return document.getElementById("mobile-overlay"); }
  function getToggle() { return document.getElementById("menu-toggle"); }

  function isMenuOpen() {
    var toggle = getToggle();
    return toggle && toggle.getAttribute("aria-expanded") === "true";
  }

  function openMenu() {
    var dd = getDropdown();
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!dd || !overlay || !toggle) return;
    overlay.classList.remove("hidden");
    dd.classList.remove("hidden");
    requestAnimationFrame(function () {
      overlay.classList.remove("opacity-0");
    });
    dd.setAttribute("aria-hidden", "false");
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
  }

  function closeMenu() {
    var dd = getDropdown();
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!dd || !overlay) return;
    overlay.classList.add("opacity-0");
    dd.classList.add("hidden");
    dd.setAttribute("aria-hidden", "true");
    overlay.addEventListener("transitionend", function handler() {
      overlay.classList.add("hidden");
      overlay.removeEventListener("transitionend", handler);
    }, { once: true });
    overlay.setAttribute("aria-hidden", "true");
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  function closeMenuSilent() {
    var dd = getDropdown();
    var overlay = getOverlay();
    if (!dd || !overlay) return;
    dd.classList.add("hidden");
    dd.setAttribute("aria-hidden", "true");
    overlay.classList.add("hidden", "opacity-0");
    overlay.setAttribute("aria-hidden", "true");
    var toggle = getToggle();
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", function (e) {
    var target = /** @type {HTMLElement} */ (e.target);

    if (target.closest("#menu-toggle")) {
      if (isMenuOpen()) {
        closeMenu();
      } else {
        openMenu();
      }
      return;
    }

    if (target.closest("[data-menu-link]")) {
      closeMenu();
      return;
    }

    if (target.closest("#mobile-overlay")) {
      closeMenu();
      return;
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      var dd = getDropdown();
      if (dd && !dd.classList.contains("hidden")) {
        closeMenu();
      }
    }
  });

  document.addEventListener("astro:before-swap", function () {
    closeMenuSilent();
  });
</script>

<style>
  #mobile-dropdown {
    background: var(--background);
  }

  [data-theme="dark"] #mobile-dropdown {
    border-color: color-mix(in srgb, var(--border) 60%, transparent);
  }

  #mobile-overlay {
    background: color-mix(in srgb, var(--background) 75%, transparent);
  }

  [data-theme="dark"] #mobile-overlay {
    background: color-mix(in srgb, black 40%, transparent);
  }
</style>

---
import IconMail from "@/assets/icons/IconMail.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import HomeTabs from "@/components/HomeTabs.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import {
  getAlternateLocale,
  getLocaleFromPath,
  localizePath,
  normalizePath,
  ui,
} from "@/i18n";

type Props = {
  compactMobile?: boolean;
};

const { compactMobile = false } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const alternateLocale = getAlternateLocale(locale);
const languageHref = localizePath(Astro.url.pathname, alternateLocale);
const emailLink = SOCIALS.find(social => social.href.startsWith("mailto:"));
const emailAddress = emailLink?.href.replace("mailto:", "");
const emailLabel = `${copy.nav.email} ${SITE.title}`;

const getHref = (path: string) => localizePath(path, locale);
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));
---

<!-- ===== Smart Sticky Header ===== -->
<header
  id="site-header"
  class="fixed top-0 w-full z-50 transition-transform duration-300 ease-in-out bg-white/80 backdrop-blur-md dark:bg-[#1e1e1e]/80"
>
<!-- ===== Topbar ===== -->
<section
  class:list={[
    "mx-auto w-full max-w-4xl px-4 pr-40 sm:px-6 lg:py-8",
    compactMobile ? "py-4" : "py-6",
  ]}
>
    <div
      class:list={[
        "font-app",
        compactMobile ? "pb-3" : "pb-4",
      ]}
    >
      <div class="flex items-center justify-between">
        <!-- Left: Logo + HomeTabs -->
        <div class="flex items-center gap-6 lg:gap-8">
          <div class="min-w-0">
            <a href={getHref("/")} class="-ml-[5px] text-[1.85rem] leading-none font-medium tracking-tight no-underline text-foreground hover:text-foreground/80 transition-colors">
              {SITE.author}
            </a>
          </div>

          <div class="hidden lg:block">
            <HomeTabs />
          </div>
        </div>

        <!-- Desktop: icon buttons -->
        <div class="hidden lg:flex items-center gap-1 translate-y-[2px]">
          <LinkButton
            href={localizePath("/search", locale)}
            class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
            title={copy.nav.search}
            aria-label={copy.nav.search}
          >
            <IconSearch class="size-5" />
            <span class="sr-only">{copy.nav.search}</span>
          </LinkButton>

          <a
            href="/rss.xml"
            class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
            title="RSS"
            aria-label="RSS"
          >
            <IconRss class="size-5" />
            <span class="sr-only">RSS</span>
          </a>

          <a
            href={languageHref}
            data-locale-target={alternateLocale}
            data-astro-reload
            class="group inline-flex size-10 items-center justify-center gap-1 rounded-full text-foreground/68 transition focus-outline hover:text-accent"
            title={copy.nav.languageLabel}
            aria-label={copy.nav.languageLabel}
          >
            <IconLanguage class="size-5" />
            <span class="sr-only">{copy.nav.languageLabel}</span>
          </a>

          {
            SITE.lightAndDarkMode && (
              <button
                id="theme-btn-desktop"
                class="focus-outline relative size-10 rounded-full text-foreground/68 transition hover:text-accent"
                title={copy.nav.theme}
                aria-label={copy.nav.theme}
                aria-live="polite"
              >
                <span
                  data-theme-icon-anchor
                  class="pointer-events-none absolute top-[50%] left-[50%] size-5 -translate-[50%]"
                  aria-hidden="true"
                >
                  <IconMoon class="absolute inset-0 h-full w-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute inset-0 h-full w-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </span>
              </button>
            )
          }
        </div>

        <!-- Mobile: search + theme (visible in topbar) -->
        <!-- Moved to fixed group below -->
      </div>
    </div>
</section>
</header>

<!-- ===== Mobile Icons (fixed group) ===== -->
<div
  class="lg:hidden fixed top-4 right-4 z-[100] flex items-center gap-1"
>
  <a
    href={localizePath("/search", locale)}
    class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
    title={copy.nav.search}
    aria-label={copy.nav.search}
    data-overlay-link
  >
    <IconSearch class="w-5 h-5" />
  </a>
  {
    SITE.lightAndDarkMode && (
      <button
        id="theme-btn"
        class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
        title={copy.nav.theme}
        aria-label={copy.nav.theme}
        aria-live="polite"
      >
        <span
          data-theme-icon-anchor
          class="pointer-events-none relative w-5 h-5"
          aria-hidden="true"
        >
          <IconMoon class="absolute inset-0 w-full h-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
          <IconSunHigh class="absolute inset-0 w-full h-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
        </span>
      </button>
    )
  }
  <button
    id="menu-toggle"
    class="group flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
    aria-label="Menu"
    aria-expanded="false"
  >
    <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out group-aria-expanded:rotate-90 group-aria-expanded:scale-50 group-aria-expanded:opacity-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="4" y1="6" x2="20" y2="6" />
      <line x1="4" y1="12" x2="20" y2="12" />
      <line x1="4" y1="18" x2="20" y2="18" />
    </svg>
    <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out -rotate-90 scale-50 opacity-0 group-aria-expanded:rotate-0 group-aria-expanded:scale-100 group-aria-expanded:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="6" y1="6" x2="18" y2="18" />
      <line x1="18" y1="6" x2="6" y2="18" />
    </svg>
  </button>
</div>

<!-- ===== Mobile Full-screen Overlay ===== -->
<div
  id="mobile-overlay"
  class="fixed inset-0 bg-white dark:bg-background z-[60] hidden flex-col items-center"
  aria-hidden="true"
>

  <!-- Nav links (centered in remaining space) -->
  <nav class="flex-grow flex flex-col items-center justify-center space-y-6">
    <a
      href={getHref("/")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.home}
    </a>
    {
      SITE.showArchives && (
        <a
          href={getHref("/archives")}
          class:list={[
            "text-xl font-medium py-2 px-8 transition-colors",
            isActive("/archives")
              ? "text-gray-900 dark:text-gray-100 font-semibold"
              : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
          ]}
          data-overlay-link
        >
          {copy.nav.archives}
        </a>
      )
    }
    <a
      href={getHref("/anime")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/anime")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.anime}
    </a>
    <a
      href={getHref("/friends")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/friends")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.friends}
    </a>
    <a
      href={getHref("/about")}
      class:list={[
        "text-xl font-medium py-2 px-8 transition-colors",
        isActive("/about")
          ? "text-gray-900 dark:text-gray-100 font-semibold"
          : "text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100",
      ]}
      data-overlay-link
    >
      {copy.nav.about}
    </a>
  </nav>

  <!-- Bottom icons (sunk to bottom) -->
  <div class="flex items-center gap-8 mb-12">
    {
      emailLink && emailAddress && (
        <a
          href={emailLink.href}
          class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
          title={emailLabel}
          aria-label={emailLabel}
        >
          <IconMail class="size-7" />
        </a>
      )
    }

    <a
      href="/rss.xml"
      class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      title="RSS"
      aria-label="RSS"
    >
      <IconRss class="size-7" />
    </a>

    <a
      href={languageHref}
      data-locale-target={alternateLocale}
      data-astro-reload
      class="text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors"
      title={copy.nav.languageLabel}
      aria-label={copy.nav.languageLabel}
    >
      <IconLanguage class="size-7" />
    </a>
  </div>
</div>

<script is:inline>
  function getOverlay() { return document.getElementById("mobile-overlay"); }
  function getToggle() { return document.getElementById("menu-toggle"); }

  function openMenu() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay || !toggle) return;
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay || !toggle) return;
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    toggle.focus();
  }

  function closeMenuSilent() {
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!overlay) return;
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", function (e) {
    var target = /** @type {HTMLElement} */ (e.target);

    if (target.closest("#menu-toggle")) {
      var toggle = getToggle();
      if (toggle && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
      } else {
        openMenu();
      }
      return;
    }

    if (target.closest("[data-overlay-link]")) {
      closeMenu();
      return;
    }

    var overlay = getOverlay();
    if (overlay && e.target === overlay && overlay.getAttribute("aria-hidden") === "false") {
      closeMenu();
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      var overlay = getOverlay();
      if (overlay && overlay.getAttribute("aria-hidden") === "false") {
        closeMenu();
      }
    }
  });

  document.addEventListener("astro:before-swap", function () {
    closeMenuSilent();
  });
</script>

<script is:inline>
  function initStickyHeader() {
    var header = document.getElementById("site-header");
    if (!header) return;
    var lastScrollY = 0;
    var ticking = false;

    function onScroll() {
      var currentY = window.scrollY;
      if (currentY > lastScrollY && currentY > 80) {
        header.classList.add("-translate-y-full");
      } else {
        header.classList.remove("-translate-y-full");
      }
      lastScrollY = currentY;
      ticking = false;
    }

    window.addEventListener("scroll", function () {
      if (!ticking) {
        requestAnimationFrame(onScroll);
        ticking = true;
      }
    }, { passive: true });
  }

  document.addEventListener("astro:page-load", initStickyHeader);
  initStickyHeader();
</script>

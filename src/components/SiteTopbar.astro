---
import IconMail from "@/assets/icons/IconMail.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import IconUser from "@/assets/icons/IconUser.svg";
import HomeTabs from "@/components/HomeTabs.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SOCIALS } from "@/constants";
import { SITE } from "@/config";
import {
  getAlternateLocale,
  getLocaleFromPath,
  localizePath,
  normalizePath,
  ui,
} from "@/i18n";

type Props = {
  compactMobile?: boolean;
};

const { compactMobile = false } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const copy = ui[locale];
const alternateLocale = getAlternateLocale(locale);
const languageHref = localizePath(Astro.url.pathname, alternateLocale);
const emailLink = SOCIALS.find(social => social.href.startsWith("mailto:"));
const emailAddress = emailLink?.href.replace("mailto:", "");
const emailLabel = `${copy.nav.email} ${SITE.title}`;

const getHref = (path: string) => localizePath(path, locale);
const currentPath = normalizePath(Astro.url.pathname);
const isActive = (path: string) => currentPath === normalizePath(getHref(path));
const isPathActive = (path: string) => currentPath.startsWith(normalizePath(getHref(path)) + "/");
---

<!-- ===== Header ===== -->
<header class="relative z-[70]">
<!-- ===== Topbar ===== -->
<section
  class:list={[
    "mx-auto w-full max-w-4xl px-5 sm:px-6 lg:py-8 border-b border-dashed border-gray-300 dark:border-gray-600",
    compactMobile ? "py-4" : "py-6",
  ]}
>
    <div
      class:list={[
        "font-app relative",
        compactMobile ? "pb-3" : "pb-4",
      ]}
    >
      <div class="flex items-center justify-between lg:grid lg:grid-cols-3">
        <!-- Left: Logo -->
        <div id="mobile-logo-area" class="min-w-0">
          <a href={getHref("/")} class="block no-underline">
            <img src="/avatar.avif" alt={SITE.author} class="size-8 rounded-full object-cover transition-transform duration-200 hover:scale-110 active:scale-90" width="32" height="32" />
          </a>
        </div>

        <!-- Center: Nav links (desktop) -->
        <div class="hidden lg:flex justify-self-center">
          <HomeTabs />
        </div>

        <!-- Right: Icons -->
        <div class="flex items-center gap-1 justify-self-end">
          <!-- Desktop icons -->
          <div class="hidden lg:flex items-center gap-4">
            <LinkButton
              href={localizePath("/search", locale)}
              class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
              title={copy.nav.search}
              aria-label={copy.nav.search}
            >
              <IconSearch class="size-5" />
              <span class="sr-only">{copy.nav.search}</span>
            </LinkButton>

            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn-desktop"
                  class="focus-outline relative size-10 rounded-full text-foreground/68 transition hover:text-accent"
                  title={copy.nav.theme}
                  aria-label={copy.nav.theme}
                  aria-live="polite"
                >
                  <span
                    data-theme-icon-anchor
                    class="pointer-events-none absolute top-[50%] left-[50%] size-5 -translate-[50%]"
                    aria-hidden="true"
                  >
                    <IconMoon class="absolute inset-0 h-full w-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                    <IconSunHigh class="absolute inset-0 h-full w-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                  </span>
                </button>
              )
            }

            <a
              href="/rss.xml"
              class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
              title="RSS"
              aria-label="RSS"
            >
              <IconRss class="size-5" />
            </a>

            <a
              href="/login"
              class="focus-outline flex size-10 items-center justify-center rounded-full text-foreground/68 transition hover:text-accent"
               title={copy.nav.login}
               aria-label={copy.nav.login}
            >
              <IconUser class="size-5" />
            </a>
          </div>

          <!-- Mobile: search + theme + menu -->
          <div class="flex lg:hidden items-center gap-1">
          <span id="mobile-header-actions" class="contents">
            <a
              href={localizePath("/search", locale)}
              class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
              title={copy.nav.search}
              aria-label={copy.nav.search}
              data-menu-link
            >
              <IconSearch class="w-5 h-5" />
            </a>
            {
              SITE.lightAndDarkMode && (
                <button
                  id="theme-btn"
                  class="flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
                  title={copy.nav.theme}
                  aria-label={copy.nav.theme}
                  aria-live="polite"
                >
                  <span
                    data-theme-icon-anchor
                    class="pointer-events-none relative w-5 h-5"
                    aria-hidden="true"
                  >
                    <IconMoon class="absolute inset-0 w-full h-full scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                    <IconSunHigh class="absolute inset-0 w-full h-full scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                  </span>
                </button>
              )
            }
          </span>
          <button
            id="menu-toggle"
            class="group flex w-10 h-10 items-center justify-center p-0 m-0 text-foreground/68 hover:text-foreground transition-colors"
            aria-label="Menu"
            aria-expanded="false"
          >
            <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out group-aria-expanded:rotate-90 group-aria-expanded:scale-50 group-aria-expanded:opacity-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
            <svg class="w-5 h-5 absolute transition-all duration-300 ease-in-out -rotate-90 scale-50 opacity-0 group-aria-expanded:rotate-0 group-aria-expanded:scale-100 group-aria-expanded:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
          </button>
          </div>   <!-- end mobile icons -->
        </div>     <!-- end right column -->
      </div>       <!-- end topbar row -->

      <!-- ===== Mobile Sidebar (slides from right) ===== -->
      <div
        id="mobile-dropdown"
        class="fixed top-0 right-0 h-full w-[35vw] min-w-[140px] max-w-[200px] bg-background border-l border-black dark:border-white z-50 translate-x-full transition-transform duration-300 ease-in-out"
        aria-hidden="true"
      >
        <nav class="h-full overflow-y-auto pb-24 pt-10">
          <a
            href={getHref("/")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-3.5 text-base text-left transition-colors",
              isActive("/")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M12 2l3.09 6.26l6.91 1l-5 4.87l1.18 6.88l-6.18 -3.25l-6.18 3.25l1.18 -6.88l-5 -4.87l6.91 -1z" /></svg>
            <span>{copy.nav.home}</span>
          </a>

          {
            SITE.showArchives && (
              <a
                href={getHref("/archives")}
                class:list={[
                  "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
                  isActive("/archives")
                    ? "bg-black text-white dark:bg-white dark:text-black"
                    : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
                ]}
                data-menu-link
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M3 4m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v0a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z" /><path d="M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-10" /><path d="M10 12l4 0" /></svg>
                <span>{copy.nav.archives}</span>
              </a>
            )
          }
          <a
            href={getHref("/weekly")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              isActive("/weekly") || isPathActive("/weekly")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M4 7a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12z" /><path d="M16 3v4" /><path d="M8 3v4" /><path d="M4 11h16" /></svg>
            <span>{copy.nav.weekly}</span>
          </a>

          <a
            href={getHref("/anime")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              isActive("/anime")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M7 4v16l13 -8z" /></svg>
            <span>{copy.nav.anime}</span>
          </a>

          <a
            href={getHref("/friends")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              isActive("/friends")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M12 20l-7.5 -7.5a5 5 0 1 1 7.5 -6.5a5 5 0 1 1 7.5 6.5l-7.5 7.5z" /></svg>
            <span>{copy.nav.friends}</span>
          </a>

          <div class="mt-6"></div>

          <a
            href={getHref("/tools")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              isActive("/tools")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M7 8l4 4l-4 4" /><path d="M13 16h4" /></svg>
            <span>{copy.nav.tools}</span>
          </a>
          <a
            href={getHref("/about")}
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              isActive("/about")
                ? "bg-black text-white dark:bg-white dark:text-black"
                : "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" /><path d="M12 9h.01" /><path d="M11 12h1v4h1" /></svg>
            <span>{copy.nav.aboutMe}</span>
          </a>

          <hr class="mx-4 my-3 border-t border-black/10 dark:border-white/10" />

          <a
            href="/login"
            class:list={[
              "flex items-center gap-2.5 px-4 py-2.5 text-base text-left transition-colors",
              "text-foreground/85 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black",
            ]}
            data-menu-link
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="size-4 shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
            <span>{copy.nav.login}</span>
          </a>

          <div class="mt-6 flex items-center justify-center gap-6 px-4">
            <a
              href="/rss.xml"
              class="text-foreground/50 hover:text-foreground transition-colors"
              title="RSS"
              aria-label="RSS"
            >
              <IconRss class="size-4" />
            </a>
            <a
              href={languageHref}
              data-locale-target={alternateLocale}
              data-astro-reload
              class="text-foreground/50 hover:text-foreground transition-colors"
              title={copy.nav.languageLabel}
              aria-label={copy.nav.languageLabel}
            >
              <IconLanguage class="size-4" />
            </a>
          </div>
        </nav>
      </div>
    </div>
</section>
</header>

<!-- ===== Mobile Menu Overlay ===== -->
<div
  id="mobile-overlay"
  class="fixed inset-0 z-40 hidden opacity-0 transition-opacity duration-200 ease-out"
  aria-hidden="true"
></div>

<script is:inline>
  function getSidebar() { return document.getElementById("mobile-dropdown"); }
  function getOverlay() { return document.getElementById("mobile-overlay"); }
  function getToggle() { return document.getElementById("menu-toggle"); }

  function isMenuOpen() {
    var toggle = getToggle();
    return toggle && toggle.getAttribute("aria-expanded") === "true";
  }

  function preventScroll(e) { e.preventDefault(); }

  function openMenu() {
    var sb = getSidebar();
    var overlay = getOverlay();
    var toggle = getToggle();
    if (!sb || !overlay || !toggle) return;
    document.body.style.overflow = "hidden";
    document.body.style.position = "fixed";
    document.body.style.width = "100%";
    document.addEventListener("touchmove", preventScroll, { passive: false });
    overlay.addEventListener("wheel", preventScroll, { passive: false });
    overlay.addEventListener("touchmove", preventScroll, { passive: false });
    overlay.classList.remove("hidden");
    sb.classList.remove("translate-x-full");
    requestAnimationFrame(function () {
      overlay.classList.remove("opacity-0");
      sb.classList.add("translate-x-0");
    });
    sb.setAttribute("aria-hidden", "false");
    overlay.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
  }

  function closeMenu() {
    var sb = getSidebar();
    var overlay = getOverlay();
    if (!sb || !overlay) return;
    document.body.style.overflow = "";
    document.body.style.position = "";
    document.body.style.width = "";
    document.removeEventListener("touchmove", preventScroll);
    overlay.removeEventListener("wheel", preventScroll);
    overlay.removeEventListener("touchmove", preventScroll);
    overlay.classList.add("opacity-0");
    sb.classList.remove("translate-x-0");
    sb.classList.add("translate-x-full");
    sb.addEventListener("transitionend", function handler() {
      overlay.classList.add("hidden");
      sb.removeEventListener("transitionend", handler);
    }, { once: true });
    sb.setAttribute("aria-hidden", "true");
    overlay.setAttribute("aria-hidden", "true");
    var toggle = getToggle();
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  function closeMenuSilent() {
    var sb = getSidebar();
    var overlay = getOverlay();
    if (!sb || !overlay) return;
    document.body.style.overflow = "";
    document.body.style.position = "";
    document.body.style.width = "";
    document.removeEventListener("touchmove", preventScroll);
    overlay.removeEventListener("wheel", preventScroll);
    overlay.removeEventListener("touchmove", preventScroll);
    sb.classList.add("translate-x-full");
    sb.classList.remove("translate-x-0");
    sb.setAttribute("aria-hidden", "true");
    overlay.classList.add("hidden", "opacity-0");
    overlay.setAttribute("aria-hidden", "true");
    var toggle = getToggle();
    if (toggle) toggle.setAttribute("aria-expanded", "false");
  }

  document.addEventListener("click", function (e) {
    var target = /** @type {HTMLElement} */ (e.target);

    if (target.closest("#menu-toggle") || target.closest("#sidebar-close")) {
      if (isMenuOpen()) {
        closeMenu();
      } else {
        openMenu();
      }
      return;
    }

    if (target.closest("[data-menu-link]")) {
      closeMenu();
      return;
    }

    if (target.closest("#mobile-overlay")) {
      closeMenu();
      return;
    }
  });

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") {
      var sb = getSidebar();
      if (sb && !sb.classList.contains("translate-x-full")) {
        closeMenu();
      }
    }
  });

  document.addEventListener("astro:before-swap", function () {
    closeMenuSilent();
  });
</script>

<style>
  #mobile-overlay {
    background: rgba(0, 0, 0, 0.5);
  }
</style>

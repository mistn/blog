---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getLocaleFromPath, localizePath, ui, type Locale } from "@/i18n";

type Props = {
  page: Page<CollectionEntry<"blog">>;
  locale?: Locale;
};

const { page, locale = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const copy = ui[locale];
const prevUrl = page.url.prev ? localizePath(page.url.prev, locale) : undefined;
const nextUrl = page.url.next ? localizePath(page.url.next, locale) : undefined;

const pages = Array.from({ length: page.lastPage }, (_, i) => ({
  number: i + 1,
  url: i + 1 === 1 ? localizePath("/", locale) : localizePath(`/posts/${i + 1}`, locale),
  current: i + 1 === page.currentPage,
}));
---

{
  page.lastPage > 1 && (
    <nav class="mt-auto mb-4 flex items-center justify-center gap-1.5 text-sm" role="navigation" aria-label="Pagination Navigation">
      {
        prevUrl ? (
          <a href={prevUrl} class="px-3 py-1.5 text-foreground/45 transition-colors hover:text-foreground rounded-lg" aria-label={copy.actions.previousPageLabel}>
            {copy.actions.previousPage}
          </a>
        ) : (
          <span class="px-3 py-1.5 text-foreground/20">{copy.actions.previousPage}</span>
        )
      }

      {pages.map(p =>
        p.current ? (
          <span class="rounded-lg bg-muted/60 px-3 py-1.5 font-semibold text-foreground">{p.number}</span>
        ) : (
          <a href={p.url} class="rounded-lg px-3 py-1.5 text-foreground/45 transition-colors hover:text-foreground">{p.number}</a>
        )
      )}

      {
        nextUrl ? (
          <a href={nextUrl} class="px-3 py-1.5 text-foreground/45 transition-colors hover:text-foreground rounded-lg" aria-label={copy.actions.nextPageLabel}>
            {copy.actions.nextPage}
          </a>
        ) : (
          <span class="px-3 py-1.5 text-foreground/20">{copy.actions.nextPage}</span>
        )
      }
    </nav>
  )
}

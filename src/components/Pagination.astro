---
import { getLocaleFromPath, ui, type Locale } from "@/i18n";

type Props = {
  currentPage: number;
  lastPage: number;
  buildPageUrl: (pageNumber: number) => string;
  locale?: Locale;
};

const {
  currentPage,
  lastPage,
  buildPageUrl,
  locale = getLocaleFromPath(Astro.url.pathname),
} = Astro.props;

const copy = ui[locale];
const prevUrl = currentPage > 1 ? buildPageUrl(currentPage - 1) : undefined;
const nextUrl = currentPage < lastPage ? buildPageUrl(currentPage + 1) : undefined;

function getPages(): (number | "...")[] {
  if (lastPage <= 5) {
    return Array.from({ length: lastPage }, (_, i) => i + 1);
  }

  if (currentPage <= 3) {
    return [1, 2, 3, "...", lastPage];
  }

  if (currentPage >= lastPage - 2) {
    return [1, "...", lastPage - 2, lastPage - 1, lastPage];
  }

  return [1, "...", currentPage, "...", lastPage];
}

const pages = getPages();
---

{
  lastPage > 1 && (
    <nav class="mt-auto mb-4 flex items-center justify-center gap-1.5 text-sm" role="navigation" aria-label="Pagination Navigation">
      {prevUrl ? (
        <a href={prevUrl} class="flex h-7 w-7 items-center justify-center text-[22px] text-foreground/45 transition-colors hover:text-foreground rounded-lg leading-none -translate-y-[2px]" aria-label={copy.actions.previousPageLabel}>
          ‹
        </a>
      ) : (
        <span class="flex h-7 w-7 items-center justify-center text-[22px] text-foreground/20 leading-none -translate-y-[2px]">‹</span>
      )}

      {pages.map(p =>
        p === "..." ? (
          <span class="flex h-7 w-7 items-center justify-center text-foreground/30">⋯</span>
        ) : p === currentPage ? (
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-muted/60 font-semibold text-foreground">{p}</span>
        ) : (
          <a href={buildPageUrl(p)} class="flex h-7 w-7 items-center justify-center rounded-lg text-foreground/45 transition-colors hover:text-foreground">{p}</a>
        )
      )}

      {nextUrl ? (
        <a href={nextUrl} class="flex h-7 w-7 items-center justify-center text-[22px] text-foreground/45 transition-colors hover:text-foreground rounded-lg leading-none -translate-y-[2px]" aria-label={copy.actions.nextPageLabel}>
          <span class="inline-block [transform:scaleX(-1)]">‹</span>
        </a>
      ) : (
        <span class="flex h-7 w-7 items-center justify-center text-[22px] text-foreground/20 leading-none -translate-y-[2px]">
          <span class="inline-block [transform:scaleX(-1)]">‹</span>
        </span>
      )}
    </nav>
  )
}

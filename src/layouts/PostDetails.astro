---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import SiteTopbar from "@/components/SiteTopbar.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ArtalkComments from "@/components/ArtalkComments.astro";
import ArticleImageLightbox from "@/components/ArticleImageLightbox.astro";
import BackButton from "@/components/BackButton.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";
import { getLocaleFromPath, localizePath, ui, type Locale } from "@/i18n";
import { transformTabs } from "@/utils/tabsPreprocessor";
import { marked } from "marked";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  locale?: Locale;
};

const {
  post,
  posts,
  locale = getLocaleFromPath(Astro.url.pathname),
} = Astro.props;
const copy = ui[locale];

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const rawBody = post.body || "";
const hasTabs = rawBody.includes("tab-item") && rawBody.includes("::: tab");

let Content;
let headings: { depth: number; slug: string; text: string }[] = [];
let tabHtml = "";

if (hasTabs) {
  const modBody = transformTabs(rawBody);
  tabHtml = marked.parse(modBody, { async: false }) as string;
} else {
  const rendered = await render(post);
  Content = rendered.Content;
  headings = rendered.headings;
}

const hasMath = rawBody.includes("$") || false;

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  locale,
};

const sortedPosts = getSortedPosts(posts);

const allPosts = sortedPosts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  {hasMath && (
    <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
  )}
  <SiteTopbar />
  <main
    id="main-content"
    data-post-memory-scope="post"
    class="app-layout pb-10 lg:max-w-4xl lg:pb-14"
  >
    <section>
      <div class="px-1 py-4 sm:px-2 sm:py-5">
        <div class="mx-auto max-w-4xl">
          <div>
            <BackButton inline {locale} />

            <article class="pt-2" data-pagefind-body>
              <h1
                data-article-enter
                style="--article-enter-delay: 0ms;"
                data-article-enter-type="title"
                class="max-w-4xl text-3xl leading-tight font-semibold tracking-tight md:text-4xl"
              >
                {title}
              </h1>

              <div
                data-article-enter
                style="--article-enter-delay: 26ms;"
                class="mt-4 flex flex-wrap items-center gap-3 text-sm text-foreground/65"
              >
                <Datetime
                  {pubDatetime}
                  {modDatetime}
                  {timezone}
                  size="lg"
                  {locale}
                  showUpdated={true}
                />
                <span
                  aria-hidden="true"
                  class:list={[
                    "max-sm:hidden",
                    { hidden: !SITE.editPost.enabled || hideEditPost },
                  ]}>|</span
                >
                <EditPost
                  {hideEditPost}
                  {post}
                  {locale}
                  class="max-sm:hidden"
                />
              </div>

              <div
                id="article"
                data-article-enter
                style="--article-enter-delay: 54ms;"
                data-article-enter-type="content"
                class="app-prose mt-10 w-full max-w-4xl mx-auto"
              >
                {hasTabs ? (
                  <div set:html={tabHtml} />
                ) : (
                  Content && <Content />
                )}
              </div>

              <div
                data-article-enter
                style="--article-enter-delay: 88ms;"
                class="mt-12 flex flex-wrap gap-3"
              >
                {tags.map(tag => (
                  <a
                    href={localizePath(`/tags/${slugifyStr(tag)}/`, locale)}
                    class="text-xs text-gray-400 hover:text-gray-900 dark:text-gray-500 dark:hover:text-gray-100 transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>

              <EditPost class="sm:hidden mt-8" {hideEditPost} {post} {locale} />

              <ArtalkComments
                pageKey={getPath(post.id, post.filePath)}
                pageTitle={title}
              />

              <div
                data-pagefind-ignore
                data-article-enter
                style="--article-enter-delay: 112ms;"
                class="mt-16 flex flex-col gap-4 sm:flex-row"
              >
                {
                  prevPost && (
                    <a
                      href={localizePath(
                        getPath(prevPost.id, prevPost.filePath),
                        locale
                      )}
                      class="group flex flex-1 items-center gap-3 rounded-xl border border-gray-100 p-4 transition-all duration-300 hover:border-gray-300 hover:bg-gray-50/50 dark:border-gray-800 dark:hover:border-gray-700 dark:hover:bg-gray-900/30"
                    >
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-gray-300 transition-all duration-300 group-hover:-translate-x-1 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400"><path d="m15 18-6-6 6-6"/></svg>
                      <div class="min-w-0">
                        <span class="block text-xs text-gray-400">{copy.actions.previousPost}</span>
                        <span class="mt-0.5 block text-sm font-medium text-gray-700 line-clamp-1 dark:text-gray-200">{prevPost.title}</span>
                      </div>
                    </a>
                  )
                }
                {
                  nextPost && (
                    <a
                      href={localizePath(
                        getPath(nextPost.id, nextPost.filePath),
                        locale
                      )}
                      class="group flex flex-1 items-center justify-end gap-3 rounded-xl border border-gray-100 p-4 text-right transition-all duration-300 hover:border-gray-300 hover:bg-gray-50/50 dark:border-gray-800 dark:hover:border-gray-700 dark:hover:bg-gray-900/30"
                    >
                      <div class="min-w-0">
                        <span class="block text-xs text-gray-400">{copy.actions.nextPost}</span>
                        <span class="mt-0.5 block text-sm font-medium text-gray-700 line-clamp-1 dark:text-gray-200">{nextPost.title}</span>
                      </div>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-gray-300 transition-all duration-300 group-hover:translate-x-1 group-hover:text-gray-500 dark:text-gray-600 dark:group-hover:text-gray-400"><path d="m9 18 6-6-6-6"/></svg>
                    </a>
                  )
                }
              </div>
            </article>
          </div>
        </div>
      </div>
    </section>
  </main>
  <ArticleImageLightbox {locale} />
  <TableOfContents slot="floating" {headings} {locale} />
</Layout>

{hasTabs && (
  <script is:inline data-astro-rerun>
    (function () {
      const style = document.getElementById("tabs-inline-style");
      if (!style) {
        const s = document.createElement("style");
        s.id = "tabs-inline-style";
        s.textContent = 'my-tabs{display:block;margin:1.5em 0;border:1px solid var(--border);border-radius:10px;overflow:hidden}my-tabs .tabs-nav{display:flex;flex-wrap:wrap;border-bottom:1px solid var(--border);background:var(--muted)}my-tabs .tabs-label{cursor:pointer;padding:.6em 1.05em;font-size:.92rem;font-weight:500;line-height:1.4;color:color-mix(in srgb,var(--foreground) 60%,transparent);background:none;border:none;outline:none;font-family:inherit;transition:color .15s,background-color .15s}my-tabs .tabs-label:hover{color:var(--foreground);background:color-mix(in srgb,var(--background) 50%,transparent)}my-tabs .tabs-label.active{color:var(--foreground);background:var(--background);box-shadow:inset 0 -2px 0 var(--accent)}my-tab{display:none;padding:1em 1.15em}my-tab.active{display:block}my-tab>:first-child{margin-top:0}my-tab>:last-child{margin-bottom:0}my-tab .code-block-frame>.code-block-header{display:none}my-tab .code-block-frame{border-radius:0;border:none;margin:0}my-tab .code-block-frame .astro-code{border-radius:.75rem}my-tab .code-block-frame::after{display:none}';
        document.head.appendChild(s);
      }

      if (customElements.get("my-tabs")) {
        document.querySelectorAll("my-tabs").forEach(el => {
          const nav = el.querySelector(":scope > .tabs-nav");
          if (nav) nav.remove();
        });
      } else {
        class MyTabs extends HTMLElement {
          connectedCallback() {
            const old = this.querySelector(":scope > .tabs-nav");
            if (old) old.remove();
            const items = Array.from(this.querySelectorAll(":scope > my-tab"));
            const nav = document.createElement("div");
            nav.className = "tabs-nav";
            items.forEach((item, i) => {
              const label = item.getAttribute("title") || `Tab ${i + 1}`;
              const btn = document.createElement("button");
              btn.className = "tabs-label";
              btn.textContent = label;
              btn.addEventListener("click", () => {
                const it = this.querySelectorAll(":scope > my-tab");
                const lb = this.querySelectorAll(":scope > .tabs-nav > .tabs-label");
                it.forEach((el, j) => el.classList.toggle("active", j === i));
                lb.forEach((el, j) => el.classList.toggle("active", j === i));
              });
              if (i === 0) btn.classList.add("active");
              nav.appendChild(btn);
            });
            this.prepend(nav);
            if (items.length > 0) items[0].classList.add("active");
          }
        }
        customElements.define("my-tabs", MyTabs);
        customElements.define("my-tab", class extends HTMLElement {});
      }

      document.querySelectorAll("my-tabs").forEach(el => {
        if (!el.querySelector(":scope > .tabs-nav")) {
          el.connectedCallback?.();
        }
      });
    })();
  </script>
)}

<script
  is:inline
  data-astro-rerun
  define:vars={{
    openImageLabel: locale === "en" ? "Open image preview" : "打开图片预览",
  }}
>
  function runArticleEnterAnimation() {
    const nodes = Array.from(document.querySelectorAll("[data-article-enter]"));

    for (const node of nodes) {
      node.classList.remove("article-enter");
      // Force a reflow so the animation reliably restarts after client-side swaps.
      void node.offsetWidth;
      node.classList.add("article-enter");
    }
  }

  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;
      link.setAttribute("aria-label", `链接到：${heading.textContent}`);

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  runArticleEnterAnimation();

  function attachImageLightbox() {
    const article = document.querySelector("#article");
    const lightbox = document.querySelector("[data-image-lightbox]");
    const preview = lightbox?.querySelector("[data-lightbox-image]");
    const caption = lightbox?.querySelector("[data-lightbox-caption]");
    const prevButton = lightbox?.querySelector("[data-lightbox-prev]");
    const nextButton = lightbox?.querySelector("[data-lightbox-next]");
    const closeButtons = Array.from(
      lightbox?.querySelectorAll("[data-lightbox-close]") ?? []
    );

    if (
      !(article instanceof HTMLElement) ||
      !(lightbox instanceof HTMLElement) ||
      !(preview instanceof HTMLImageElement) ||
      !(caption instanceof HTMLElement) ||
      !(prevButton instanceof HTMLButtonElement) ||
      !(nextButton instanceof HTMLButtonElement)
    ) {
      return;
    }

    const images = Array.from(article.querySelectorAll("img[src]")).filter(
      image => image instanceof HTMLImageElement
    );
    let currentIndex = 0;
    let previousFocus = null;

    for (const image of images) {
      if (!(image instanceof HTMLImageElement)) continue;
      image.classList.add("article-lightbox-image");
      image.tabIndex = 0;
      image.setAttribute("role", "button");
      image.setAttribute("aria-label", image.alt || openImageLabel);
      image.addEventListener("click", event => {
        event.preventDefault();
        openLightbox(images.indexOf(image));
      });
      image.addEventListener("keydown", event => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        openLightbox(images.indexOf(image));
      });
    }

    for (const button of closeButtons) {
      button.addEventListener("click", closeLightbox);
    }

    prevButton.addEventListener("click", () => showImage(currentIndex - 1));
    nextButton.addEventListener("click", () => showImage(currentIndex + 1));

    lightbox.addEventListener("keydown", event => {
      if (event.key === "Escape") {
        closeLightbox();
      } else if (event.key === "ArrowLeft") {
        showImage(currentIndex - 1);
      } else if (event.key === "ArrowRight") {
        showImage(currentIndex + 1);
      }
    });

    function openLightbox(index) {
      if (index < 0) return;
      previousFocus = document.activeElement;
      showImage(index);
      lightbox.hidden = false;
      document.documentElement.classList.add("has-image-lightbox");
      requestAnimationFrame(() => lightbox.focus());
    }

    function closeLightbox() {
      lightbox.hidden = true;
      document.documentElement.classList.remove("has-image-lightbox");

      if (previousFocus instanceof HTMLElement) {
        previousFocus.focus();
      }
    }

    function showImage(index) {
      currentIndex = (index + images.length) % images.length;
      const image = images[currentIndex];

      if (!(image instanceof HTMLImageElement)) return;

      preview.src = image.currentSrc || image.src;
      preview.alt = image.alt;

      const captionText = image.alt.trim();
      caption.textContent = captionText;
      caption.hidden = captionText.length === 0;

      const hasMultipleImages = images.length > 1;
      prevButton.hidden = !hasMultipleImages;
      nextButton.hidden = !hasMultipleImages;
    }
  }
  attachImageLightbox();

  document.addEventListener("astro:after-swap", () => {
    const isPostScope = document.querySelector(
      '[data-post-memory-scope="post"]'
    );
    if (!isPostScope) return;
    window.scrollTo({ left: 0, top: 0, behavior: "instant" });
  });
</script>
